# R session / history
.Rhistory
.RData
*.RData
.R-lib/
.Rproj.user/
.Ruserdata
*.Rproj

# Snakemake
.snakemake/
logs/

# Quarto
/.quarto/
report/_freeze/
report/*.html
!docs/index.html

# Python / virtualenv (in case Snakemake env leaks in)
__pycache__/
*.pyc
.venv/
.env

# OS junk
.DS_Store
Thumbs.db

# Raw and intermediate data - never commit
data/*
!data/demo/
!data/.gitkeep
!data/README.md
data/demo/*
!data/demo/.gitkeep

# Generated results - only curated example stubs are committed
results/*
!results/example/
!results/.gitkeep
!results/README.md

# Guard against accidentally running scripts from workflow/scripts/
workflow/scripts/data/
workflow/scripts/results/
workflow/scripts/docs/
workflow/scripts/.Rhistory
workflow/scripts/*.RData

# Container build artifacts
containers/*.sif
containers/*.img

# Editor
.vscode/
.idea/
*.swp

# Claude Code / agent tooling
.claude/

# Generated implementation notes / temporary run artifacts
IMPLEMENTATION_COMPLETE.md
PIPELINE_IMPLEMENTATION_SUMMARY.md
README_IMPLEMENTATION.md
SOLUTION_TO_GREENYELLOW_DISCOVERY.md
VALIDATION_CHECKLIST.md
